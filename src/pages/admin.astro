---
export const prerender = true;

import { withBase } from "../lib/paths";

const adminConfigPath = withBase("/admin/config.yml");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portfolio CMS</title>
  </head>
  <body>
    <main id="cms-setup" hidden>
      <h1>CMS Setup Required</h1>
      <p>
        This template demo is deployed with a placeholder Decap OAuth provider.
        To write locally, run the Astro dev server and Decap local backend, then
        open the local admin URL.
      </p>
      <pre>npm run dev
npm run cms</pre>
      <p>Local admin: <code>http://127.0.0.1:4321/admin/</code></p>
      <p>
        For production editing, replace <code>backend.base_url</code> in
        <code>public/admin/config.yml</code> with your GitHub OAuth proxy URL.
      </p>
    </main>
    <script is:inline define:vars={{ adminConfigPath }}>
      const isLocal =
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1";

      function loadCms() {
        const script = document.createElement("script");
        script.src = "https://unpkg.com/decap-cms@^3.6.0/dist/decap-cms.js";
        document.body.appendChild(script);
      }

      fetch(adminConfigPath)
        .then((response) => response.text())
        .then((config) => {
          const usesPlaceholderAuth = config.includes(
            "https://your-auth-provider.example.com",
          );

          if (!isLocal && usesPlaceholderAuth) {
            document.getElementById("cms-setup")?.removeAttribute("hidden");
            return;
          }

          loadCms();
        })
        .catch(() => {
          document.getElementById("cms-setup")?.removeAttribute("hidden");
        });
    </script>
    <style>
      body {
        color: #333;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        margin: 0;
      }

      main {
        margin: 0 auto;
        max-width: 680px;
        padding: 64px 24px;
      }

      h1 {
        color: #111;
        font-size: 32px;
        line-height: 1.2;
        margin: 0 0 16px;
      }

      p {
        font-size: 16px;
        line-height: 1.6;
      }

      pre {
        background: #f5f5f5;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        overflow-x: auto;
        padding: 16px;
      }

      code {
        color: #111;
      }
    </style>
  </body>
</html>
