---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getReadingTime } from "../../../lib/readingTime";
import { withBase } from "../../../lib/paths";
import { getPostBody, getPostSlug, type BlogPost } from "../../../lib/blog";

type Paginate = (data: BlogPost[], options: { pageSize: number }) => unknown;

type Page = {
  data: BlogPost[];
  currentPage: number;
  lastPage: number;
  url: {
    prev?: string;
    next?: string;
  };
};

export async function getStaticPaths({ paginate }: { paginate: Paginate }) {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );

  return paginate(posts, { pageSize: 6 });
}

const { page } = Astro.props as { page: Page };
const formatDate = (date: Date) =>
  date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout title={`Insights - Page ${page.currentPage}`}>
  <section class="pb-10">
    <h1 class="font-headline text-xl font-normal text-primary">Insights</h1>
    <p class="mt-3 max-w-prose font-headline text-base text-secondary">
      Writing on engineering, frontend craft, and building in public.
    </p>
  </section>

  <section class="space-y-12 py-6">
    {
      page.data.map((post) => (
        <article>
          <p class="mb-2 font-label text-xs text-subtle">
            {formatDate(post.data.publishDate)} · {getReadingTime(getPostBody(post))}
          </p>
          <h2 class="font-headline text-lg font-normal text-primary">
            <a
              class="underline underline-offset-4"
              href={withBase(`/insights/${getPostSlug(post)}/`)}
            >
              {post.data.title}
            </a>
          </h2>
          <p class="mt-3 max-w-prose font-headline text-base text-secondary">
            {post.data.description}
          </p>
          <div class="mt-4 flex flex-wrap gap-3 font-label text-xs text-muted">
            {post.data.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>
      ))
    }
  </section>

  <nav class="mt-12 flex gap-4 font-label text-xs text-primary">
    {
      page.url.prev && (
        <a class="underline underline-offset-4" href={page.url.prev}>
          Previous
        </a>
      )
    }
    <span>Page {page.currentPage} of {page.lastPage}</span>
    {
      page.url.next && (
        <a class="underline underline-offset-4" href={page.url.next}>
          Next
        </a>
      )
    }
  </nav>
</BaseLayout>
