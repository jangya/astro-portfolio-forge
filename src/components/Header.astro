---
import { siteConfig } from "../config";
import { withBase } from "../lib/paths";

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return currentPath === withBase("/");
  return currentPath.includes(href);
};
---

<header class="mx-auto max-w-content px-6 pb-18 pt-12 md:px-0">
  <nav class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
    <a class="grid grid-cols-[72px_minmax(0,1fr)] items-center gap-5" href={withBase("/")}>
      <img
        class="h-[72px] w-[72px] rounded-full object-cover grayscale"
        src={siteConfig.avatar}
        alt=""
      />
      <span class="min-w-0">
        <span class="block font-label text-[1.85rem] font-bold leading-[1.15] text-primary">
          {siteConfig.name}
        </span>
        <span class="mt-1 block font-label text-[1rem] leading-[1.35] text-muted">
          {siteConfig.tagline}
        </span>
      </span>
    </a>
    <div class="flex flex-wrap items-center gap-x-8 gap-y-3 pt-1 font-headline text-[1.18rem] leading-[1.5] text-accent md:justify-end">
      {
        siteConfig.nav.map((item) => (
          <a
            class:list={[
              "underline-offset-4 hover:underline",
              isActive(item.href) ? "text-primary" : "text-accent",
            ]}
            href={withBase(item.href)}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
